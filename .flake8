[flake8]
max-line-length = 88
extend-ignore = E203, W503, E501, I
exclude =
    .git,
    __pycache__,
    migrations,
    venv,
    env,
    build,
    dist,
    .venv,
    .eggs,
    *.egg-info,
    .pytest_cache,
    htmlcov
per-file-ignores =
    __init__.py:F401
    settings/*:F403,F405
    tests/*:F401,F811
max-complexity = 20
# Remove problematic import-order-style that conflicts with isort
# import-order-style = django
application-import-names = portfolio_management
